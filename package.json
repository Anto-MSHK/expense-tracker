{
  "name": "expense-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Offline-first PWA трекер расходов (TypeScript + React + Node.js + PostgreSQL)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"pnpm --filter @expense/api dev\" \"pnpm --filter @expense/web dev\"",
    "build": "pnpm --filter @expense/shared build && pnpm --filter @expense/api build && pnpm --filter @expense/web build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @expense/api db:migrate",
    "db:generate": "pnpm --filter @expense/api db:generate",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
