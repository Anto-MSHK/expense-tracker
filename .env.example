# Скопируйте в .env (docker compose и api читают эти переменные)
# --- PostgreSQL ---
POSTGRES_USER=expense
POSTGRES_PASSWORD=expense
POSTGRES_DB=expense_tracker
POSTGRES_PORT=5432

# --- API ---
# Строка подключения, собранная из переменных выше
DATABASE_URL=postgresql://expense:expense@localhost:5432/expense_tracker
API_PORT=3001
# Разрешённый origin фронтенда для CORS
CORS_ORIGIN=http://localhost:5173
